{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FormulaSnap",
  "version": "0.1.0",
  "identifier": "com.formulasnap.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "FormulaSnap",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8477 ipc: http://ipc.localhost; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data: asset: http://asset.localhost; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/formulasnap-sidecar"
    ],
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY1OTFCNkUzRTkzNkEwOUEKUldTYW9EYnA0N2FSWmFJb3lrK01IVXJCL0RMVU1rUXZlYUZMWFg1blZrdlQ1ZGJHSUdkaWtFUDcK",
      "endpoints": [
        "https://github.com/wangdi94/FormulaSnap/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
