# Auto-detect text files and normalize to LF
* text=auto

# Source code - always LF
*.rs    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf

# Python
*.py    text eol=lf
*.pyi   text eol=lf

# Shell scripts
*.sh    text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Make sure git doesn't try to diff binaries
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff2 binary
